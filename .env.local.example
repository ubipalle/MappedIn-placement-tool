# MappedIn credentials (server-side only — never exposed to browser)
MAPPEDIN_API_KEY=
MAPPEDIN_API_SECRET=

# Optional: default map ID (auto-loads if set, bypasses project code entry)
MAPPEDIN_DEFAULT_MAP_ID=

# GDrive integration — for loading project config by project code
# Service account JSON (same as project-orchestrator)
GOOGLE_SERVICE_ACCOUNT_KEY_JSON=
# Root GDrive folder ID containing all project folders
GDRIVE_ROOT_FOLDER_ID=
